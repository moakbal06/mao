{
  "name": "@moakbal/mao-cli",
  "version": "0.2.2",
  "description": "CLI for agent-orchestrator — the `ao` command",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ao": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "templates"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/moakbal06/mao.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/moakbal06/mao",
  "bugs": {
    "url": "https://github.com/moakbal06/mao/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc && cp -r src/assets dist/",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@moakbal/mao-core": "workspace:*",
    "@moakbal/mao-plugin-agent-aider": "workspace:*",
    "@moakbal/mao-plugin-agent-claude-code": "workspace:*",
    "@moakbal/mao-plugin-agent-codex": "workspace:*",
    "@moakbal/mao-plugin-agent-opencode": "workspace:*",
    "@moakbal/mao-plugin-notifier-composio": "workspace:*",
    "@moakbal/mao-plugin-notifier-desktop": "workspace:*",
    "@moakbal/mao-plugin-notifier-discord": "workspace:*",
    "@moakbal/mao-plugin-notifier-openclaw": "workspace:*",
    "@moakbal/mao-plugin-notifier-slack": "workspace:*",
    "@moakbal/mao-plugin-notifier-webhook": "workspace:*",
    "@moakbal/mao-plugin-runtime-process": "workspace:*",
    "@moakbal/mao-plugin-runtime-tmux": "workspace:*",
    "@moakbal/mao-plugin-scm-github": "workspace:*",
    "@moakbal/mao-plugin-terminal-iterm2": "workspace:*",
    "@moakbal/mao-plugin-terminal-web": "workspace:*",
    "@moakbal/mao-plugin-tracker-github": "workspace:*",
    "@moakbal/mao-plugin-tracker-jira": "workspace:*",
    "@moakbal/mao-plugin-tracker-linear": "workspace:*",
    "@moakbal/mao-plugin-workspace-clone": "workspace:*",
    "@moakbal/mao-plugin-workspace-direct": "workspace:*",
    "@moakbal/mao-plugin-workspace-worktree": "workspace:*",
    "@moakbal/mao-web": "workspace:*",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "dotenv": "^17.4.1",
    "ora": "^8.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
